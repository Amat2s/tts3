# Frontend environment variables (prefix with VITE_ to expose to the browser)

# Backend API base URL
# Development: use /api (Vite proxies /api/* → http://127.0.0.1:8000/* — avoids CORS entirely)
# Production: set to the absolute backend URL, e.g. https://api.example.com
VITE_API_BASE_URL=/api

# Supabase project credentials (public anon key is safe to expose in the browser)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sentry frontend crash reporting (optional)
# Leave VITE_SENTRY_DSN unset to disable Sentry — the app runs normally without it.
# The DSN is a public client key and is safe to expose in the browser.
VITE_SENTRY_DSN=
# Environment tag attached to Sentry events; defaults to the Vite build mode when unset.
VITE_ENVIRONMENT=development
