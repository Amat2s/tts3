# Trigger.dev environment variables for the jobs boundary.
# Copy to a per-environment file — `.env.development` or `.env.production` — NOT
# plain `.env`. The npm scripts load the right one and set APP_ENV, which picks
# the Trigger project ref in trigger.config.ts:
#   npm run dev          # development  (.env.development, dev project)
#   npm run dev:prod     # production   (.env.production, prod project)
#   npm run deploy       # production   (.env.production, prod project)
#   npm run deploy:dev   # development  (.env.development, dev project)
# All real .env.* files are gitignored. Set TRIGGER_PROJECT_REF to override the
# ref for the selected environment.

# Personal Access Token for non-interactive auth (CI / deploy).
# For local development you can instead authenticate interactively with:
#   npm run login   (wraps `trigger.dev login`)
# Generate a token in the Trigger.dev dashboard under your account settings.
TRIGGER_ACCESS_TOKEN=

# Server API key ("secret key") for the environment. Required only when a
# backend service triggers tasks via the SDK. NOT required to run the local
# dev server. Find it in the dashboard under Project settings → API keys.
TRIGGER_SECRET_KEY=

# NOTE: The Trigger.dev project ref is configured in trigger.config.ts
# (the `project` field), not here. Replace the placeholder there.

# --- Solver execution bridge ---
# The `solver-job` task has two execution paths. It uses the HTTP bridge when
# SOLVER_EXECUTE_URL is set (this is the PRODUCTION path — the deployed worker
# has no Python), and otherwise the local Python spawn bridge.

# --- Production: HTTP bridge (Unit 56) ---
# Absolute URL of the deployed backend's internal execute endpoint. When set,
# the task POSTs the run reference here instead of spawning Python, and the
# backend runs the solver pipeline and applies the result safely. Example:
#   https://<service>.up.railway.app/solver/internal/execute
SOLVER_EXECUTE_URL=
# Shared secret presented to the backend as a Bearer token. MUST equal the
# backend's SOLVER_INTERNAL_TOKEN. Server-to-server only — never a frontend
# value. See docs/trigger-dev-deployment.md.
SOLVER_EXECUTE_TOKEN=

# --- Local development: Python spawn bridge (Unit 45) ---
# Used only when SOLVER_EXECUTE_URL is NOT set. The task invokes the backend
# Python solver pipeline via `python -m solver.job_cli` on the same machine.
#
# ABSOLUTE path to the repo's backend/ directory. REQUIRED in practice:
# Trigger.dev does NOT run the task with its working directory set to jobs/,
# so a relative/auto-derived default is unreliable. The bridge runs with this
# as its CWD (so backend imports and backend/.env resolve). Examples:
#   C:\Users\you\path\to\repo\backend      (Windows)
#   /home/you/path/to/repo/backend         (macOS/Linux)
BACKEND_DIR=
# Python interpreter to run the bridge. May be absolute, a path relative to
# BACKEND_DIR, or a bare command on PATH (default `python`). Point this at the
# backend virtualenv interpreter, e.g.
#   .venv\Scripts\python.exe   (Windows, relative to BACKEND_DIR)
#   .venv/bin/python           (macOS/Linux, relative to BACKEND_DIR)
PYTHON_BIN=
#
# The backend process reads DATABASE_URL / SUPABASE_URL from backend/.env (it
# builds the solver input from saved database state), so the bridge needs the
# backend environment configured — not a duplicate DB URL here.
