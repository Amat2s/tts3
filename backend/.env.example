DATABASE_URL=
SUPABASE_URL=
CORS_ORIGINS=["http://localhost:5173"]

# Required only when POST /solver/start should queue the real Trigger.dev task.
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_SOLVER_TASK_ID=solver-job

# Observability (Unit 49).
# SENTRY_DSN is optional — when empty, the backend runs normally and no events
# are sent. ENVIRONMENT tags captured exceptions and logs (e.g. development,
# staging, production). Do not log auth tokens, secrets, database URLs, or full
# student payloads anywhere.
SENTRY_DSN=
ENVIRONMENT=development
