DATABASE_URL=
SUPABASE_URL=
CORS_ORIGINS=["http://localhost:5173"]

# Required only when POST /solver/start should queue the real Trigger.dev task.
TRIGGER_SECRET_KEY=
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_SOLVER_TASK_ID=solver-job

# Shared secret authorizing the deployed Trigger.dev solver worker to call the
# internal execute endpoint (POST /solver/internal/execute). Server-to-server
# only — NEVER expose to the frontend. When empty, the internal endpoint fails
# closed (503). Use a long random value, e.g. `openssl rand -hex 32`. The jobs
# worker must be given the SAME value as SOLVER_EXECUTE_TOKEN. See
# docs/trigger-dev-deployment.md.
SOLVER_INTERNAL_TOKEN=

# Observability (Unit 49).
# SENTRY_DSN is optional — when empty, the backend runs normally and no events
# are sent. ENVIRONMENT tags captured exceptions and logs (e.g. development,
# staging, production). Do not log auth tokens, secrets, database URLs, or full
# student payloads anywhere.
SENTRY_DSN=
ENVIRONMENT=development
